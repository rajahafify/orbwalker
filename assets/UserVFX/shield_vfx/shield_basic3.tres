code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform float wobbleIntensity2 = 1.0;
uniform float wobbleFrecuency = 5.0;
uniform float wobble_speed = 5.0;
uniform float Intensity;
uniform vec4 Color : source_color;
uniform vec2 scale;
uniform sampler2D transparent_texture : source_color;
uniform vec4 fresnel_color : source_color;
uniform float fresnel_power;
uniform vec2 scale_lines;
uniform vec2 direction;
uniform float speed;
uniform sampler2D scanlines;
uniform sampler2D gradient;



void vertex() {
// FloatParameter:26
	float n_out26p0 = wobbleIntensity2;


// VectorCompose:24
	float n_in24p0 = 0.00000;
	float n_in24p2 = 0.00000;
	vec3 n_out24p0 = vec3(n_in24p0, n_out26p0, n_in24p2);


// Input:5
	vec2 n_out5p0 = UV;
	float n_out5p2 = n_out5p0.g;


// SmoothStep:7
	float n_in7p0 = 0.00000;
	float n_in7p1 = 1.00000;
	float n_out7p0 = smoothstep(n_in7p0, n_in7p1, n_out5p2);


// FloatParameter:25
	float n_out25p0 = wobbleFrecuency;


// FloatParameter:3
	float n_out3p0 = wobble_speed;


// Input:2
	float n_out2p0 = TIME;


// FloatOp:4
	float n_out4p0 = n_out3p0 * n_out2p0;


// FloatOp:6
	float n_out6p0 = n_out5p2 * n_out4p0;


// FloatOp:15
	float n_out15p0 = n_out25p0 * n_out6p0;


// FloatFunc:17
	float n_out17p0 = sin(n_out15p0);


// FloatFunc:27
	float n_out27p0 = -(n_out17p0);


// FloatOp:16
	float n_in16p0 = 0.10000;
	float n_out16p0 = n_in16p0 * n_out27p0;


// FloatOp:18
	float n_out18p0 = n_out7p0 * n_out16p0;


// VectorOp:23
	vec3 n_out23p0 = n_out24p0 * vec3(n_out18p0);


// Input:14
	vec3 n_out14p0 = VERTEX;


// VectorOp:19
	vec3 n_out19p0 = n_out23p0 * n_out14p0;


// Input:21
	vec3 n_out21p0 = VERTEX;


// VectorOp:13
	vec3 n_in13p1 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out13p0 = n_out21p0 + n_in13p1;


// VectorOp:20
	vec3 n_out20p0 = n_out19p0 + n_out13p0;


// Output:0
	VERTEX = n_out20p0;


}

void fragment() {
// FloatParameter:14
	float n_out14p0 = Intensity;


// ColorParameter:4
	vec4 n_out4p0 = Color;


// VectorOp:15
	vec3 n_out15p0 = vec3(n_out14p0) * vec3(n_out4p0.xyz);


// Vector2Parameter:18
	vec2 n_out18p0 = scale;


// UVFunc:12
	vec2 n_in12p2 = vec2(0.00000, 0.00000);
	vec2 n_out12p0 = (UV - n_in12p2) * n_out18p0 + n_in12p2;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(transparent_texture, n_out12p0);


// VectorOp:11
	vec3 n_out11p0 = n_out15p0 * vec3(n_out3p0.xyz);


// ColorParameter:23
	vec4 n_out23p0 = fresnel_color;


// FloatParameter:25
	float n_out25p0 = fresnel_power;


// Fresnel:24
	float n_out24p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out25p0);


// Mix:26
	vec3 n_out26p0 = mix(n_out11p0, vec3(n_out23p0.xyz), vec3(n_out24p0));


// Vector2Parameter:39
	vec2 n_out39p0 = scale_lines;


// UVFunc:38
	vec2 n_in38p2 = vec2(0.00000, 0.00000);
	vec2 n_out38p0 = (UV - n_in38p2) * n_out39p0 + n_in38p2;


// Vector2Parameter:37
	vec2 n_out37p0 = direction;


// Input:30
	float n_out30p0 = TIME;


// FloatParameter:33
	float n_out33p0 = speed;


// FloatOp:32
	float n_out32p0 = n_out30p0 * n_out33p0;


// UVFunc:29
	vec2 n_out29p0 = vec2(n_out32p0) * n_out37p0 + n_out38p0;


	vec4 n_out35p0;
// Texture2D:35
	n_out35p0 = texture(scanlines, n_out29p0);


	vec4 n_out17p0;
// Texture2D:17
	n_out17p0 = texture(gradient, UV);


// VectorOp:10
	vec3 n_out10p0 = vec3(n_out3p0.xyz) * vec3(n_out17p0.xyz);


// MultiplyAdd:41
	vec3 n_out41p0 = fma(vec3(n_out35p0.xyz), vec3(n_out17p0.xyz), n_out10p0);


// Fresnel:28
	float n_in28p3 = 3.00000;
	float n_out28p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_in28p3);


// Mix:27
	vec3 n_in27p0 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out27p0 = mix(n_in27p0, n_out41p0, vec3(n_out28p0));


// Output:0
	ALBEDO = n_out26p0;
	ALPHA = n_out27p0.x;


}
"
