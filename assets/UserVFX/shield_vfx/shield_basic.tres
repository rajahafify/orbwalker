[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, vertex_lighting;

uniform float Intensity;
uniform vec4 Color : source_color;
uniform vec2 direction;
uniform vec2 scale;
uniform sampler2D transparent_texture : source_color;
uniform vec4 fresnel_color : source_color;
uniform float fresnel_power;
uniform sampler2D gradient;



void fragment() {
// FloatParameter:14
	float n_out14p0 = Intensity;


// ColorParameter:4
	vec4 n_out4p0 = Color;


// VectorOp:15
	vec3 n_out15p0 = vec3(n_out14p0) * vec3(n_out4p0.xyz);


// Vector2Parameter:8
	vec2 n_out8p0 = direction;


// Input:6
	float n_out6p0 = TIME;


// UVFunc:5
	vec2 n_out5p0 = vec2(n_out6p0) * n_out8p0 + UV;


// Vector2Parameter:18
	vec2 n_out18p0 = scale;


// UVFunc:12
	vec2 n_in12p2 = vec2(0.00000, 0.00000);
	vec2 n_out12p0 = (n_out5p0 - n_in12p2) * n_out18p0 + n_in12p2;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(transparent_texture, n_out12p0);


// VectorOp:11
	vec3 n_out11p0 = n_out15p0 * vec3(n_out3p0.xyz);


// ColorParameter:19
	vec4 n_out19p0 = fresnel_color;


// FloatParameter:22
	float n_out22p0 = fresnel_power;


// Fresnel:21
	float n_out21p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out22p0);


// Mix:20
	vec3 n_out20p0 = mix(n_out11p0, vec3(n_out19p0.xyz), vec3(n_out21p0));


	vec4 n_out17p0;
// Texture2D:17
	n_out17p0 = texture(gradient, UV);


// VectorOp:10
	vec3 n_out10p0 = vec3(n_out3p0.xyz) * vec3(n_out17p0.xyz);


// Output:0
	ALBEDO = n_out20p0;
	ALPHA = n_out10p0.x;


}
"
